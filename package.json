{
  "name": "with-tailwind",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "postinstall": "turbo run generate",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "@prisma/client": "^6.2.1",
    "dotenv": "^17.4.2",
    "prettier": "^3.6.0",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "prisma": "^6.2.1",
    "turbo": "^2.9.6"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@types/pg": "^8.20.0",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  }
}
