generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String                 @id @default(uuid())
  email          String                 @unique
  name           String
  role           String                 @default("TECH")
  password       String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  contracts      InstallationContract[]
  ticketMessages TicketMessage[]

  @@map("users")
}

model InstallationContract {
  id                String          @id @default(uuid())
  contractNumber    String          @unique
  status            String          @default("PENDING")
  clientName        String
  clientEmail       String
  clientPhone       String
  clientDni         String
  companyName       String?
  address           String
  city              String?         @default("Por definir")
  province          String?         @default("Por definir")
  country           String          @default("Argentina")
  equipmentType     String
  planType          String
  monthlyFee        Float?
  kitSerialNumber   String?
  hardwareVersion   String?
  antennaLocation   String?
  obstructions      String?
  downloadSpeed     Float?
  uploadSpeed       Float?
  latency           Int?
  networkMode       String?
  techSignature     String?
  clientSignature   String?
  photoCasa         String?
  photoAntena       String?
  photoRouter       String?
  photoCable        String?
  photoTest         String?
  technicianId      String?
  installationNotes String?
  techNotes         String?
  scheduledDate     DateTime?
  installedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  alturaCheck       Boolean?        @default(false)
  antennaModel      String?
  cableColor        String?
  latitude          Float?
  longitude         Float?
  routerCheck       Boolean?        @default(false)
  soporteCheck      Boolean?        @default(false)
  speedCheck        Boolean?        @default(false)
  terminalId        String?
  photoApp          String?
  photoRack         String?
  photoSoporte      String?
  clientCategory    String?
  houseNumber       String?
  street            String?
  zipCode           String?
  obstructionObject String?
  perfObservations  String?
  clientSignedAt    DateTime?
  techDni           String?
  techName          String?
  techSignedAt      DateTime?
  technician        User?           @relation(fields: [technicianId], references: [id])
  tickets           SupportTicket[]

  @@map("installation_contracts")
}

model SupportTicket {
  id           String               @id @default(uuid())
  ticketNumber String
  title        String
  description  String
  category     String
  status       String               @default("OPEN")
  priority     String               @default("MEDIUM")
  contractId   String
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  contract     InstallationContract @relation(fields: [contractId], references: [id])
  messages     TicketMessage[]

  @@map("support_tickets")
}

model TicketMessage {
  id          String        @id @default(uuid())
  content     String
  attachments String?
  authorId    String?
  ticketId    String
  createdAt   DateTime      @default(now())
  author      User?         @relation(fields: [authorId], references: [id])
  ticket      SupportTicket @relation(fields: [ticketId], references: [id])

  @@map("ticket_messages")
}

model Asset {
  id             String   @id @default(uuid())
  name           String
  technologyType String
  attributes     String
  status         String   @default("ACTIVE")
  locationId     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  location       Location @relation(fields: [locationId], references: [id])
}

model Location {
  id        String   @id @default(uuid())
  latitude  Float
  longitude Float
  address   String?
  city      String   @default("Mendoza")
  province  String   @default("Mendoza")
  country   String   @default("Argentina")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assets    Asset[]
}
