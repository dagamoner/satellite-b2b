generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String                 @id @default(uuid())
  email            String                 @unique
  name             String
  role             String                 @default("TECH")
  password         String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  contracts        InstallationContract[]
  ticketMessages   TicketMessage[]
  internalMessages InternalMessage[]
  leads            Lead[]
  activities       ClientActivity[]

  @@map("users")
}

model InstallationContract {
  id                String          @id @default(uuid())
  contractNumber    String          @unique
  status            String          @default("PENDING")
  clientName        String
  clientEmail       String
  clientPhone       String
  clientDni         String
  companyName       String?
  address           String
  city              String?         @default("Por definir")
  province          String?         @default("Por definir")
  country           String          @default("Argentina")
  equipmentType     String
  planType          String
  monthlyFee        Float?
  kitSerialNumber   String?
  hardwareVersion   String?
  antennaLocation   String?
  obstructions      String?
  downloadSpeed     Float?
  uploadSpeed       Float?
  latency           Int?
  networkMode       String?
  techSignature     String?
  clientSignature   String?
  photoCasa         String?
  photoAntena       String?
  photoRouter       String?
  photoCable        String?
  photoTest         String?
  technicianId      String?
  installationNotes String?
  techNotes         String?
  scheduledDate     DateTime?
  installedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  alturaCheck       Boolean?        @default(false)
  antennaModel      String?
  cableColor        String?
  latitude          Float?
  longitude         Float?
  routerCheck       Boolean?        @default(false)
  soporteCheck      Boolean?        @default(false)
  speedCheck        Boolean?        @default(false)
  terminalId        String?
  photoApp          String?
  photoRack         String?
  photoSoporte      String?
  clientCategory    String?
  houseNumber       String?
  street            String?
  zipCode           String?
  obstructionObject String?
  perfObservations  String?
  clientSignedAt    DateTime?
  techDni           String?
  techName          String?
  techSignedAt      DateTime?
  accountId         String?
  technician        User?           @relation(fields: [technicianId], references: [id])
  account           CustomerAccount? @relation(fields: [accountId], references: [id])
  tickets           SupportTicket[]

  @@map("installation_contracts")
}

model SupportTicket {
  id           String               @id @default(uuid())
  ticketNumber String
  title        String
  description  String
  category     String
  status       String               @default("OPEN")
  priority     String               @default("MEDIUM")
  contractId   String
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  contract     InstallationContract @relation(fields: [contractId], references: [id])
  messages     TicketMessage[]

  @@map("support_tickets")
}

model TicketMessage {
  id          String        @id @default(uuid())
  content     String
  attachments String?
  authorId    String?
  ticketId    String
  createdAt   DateTime      @default(now())
  author      User?         @relation(fields: [authorId], references: [id])
  ticket      SupportTicket @relation(fields: [ticketId], references: [id])

  @@map("ticket_messages")
}

model InternalMessage {
  id        String   @id @default(uuid())
  content   String
  senderId  String
  createdAt DateTime @default(now())
  
  sender    User     @relation(fields: [senderId], references: [id])

  @@map("internal_messages")
}

model Asset {
  id             String   @id @default(uuid())
  name           String
  technologyType String
  attributes     String
  status         String   @default("ACTIVE")
  locationId     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  location       Location @relation(fields: [locationId], references: [id])
}

model Location {
  id        String   @id @default(uuid())
  latitude  Float
  longitude Float
  address   String?
  city      String   @default("Mendoza")
  province  String   @default("Mendoza")
  country   String   @default("Argentina")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assets    Asset[]
}

model CustomerAccount {
  id             String                 @id @default(uuid())
  companyName    String
  taxId          String                 @unique // CUIT/DNI
  industry       String?                // Corporativo, Pyme, Minería, Agro, etc.
  phone          String
  email          String                 @unique
  address        String
  city           String
  province       String
  country        String                 @default("Argentina")
  tier           String                 @default("STANDARD") // GOLD, PLATINUM, ENTERPRISE
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  
  // Relaciones
  contracts      InstallationContract[]
  activities     ClientActivity[]
  invoices       Invoice[]

  @@map("customer_accounts")
}

model Lead {
  id             String           @id @default(uuid())
  leadNumber     String           @unique // Ex: L-10023
  clientName     String
  companyName    String?
  email          String
  phone          String
  source         String           @default("WEB_MARKETING") // WEB_MARKETING, MANUAL, REFERRAL
  status         String           @default("NEW") // NEW, CONTACTED, FEASIBILITY, WON, LOST
  latitude       Float?
  longitude      Float?
  notes          String?
  assignedToId   String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relaciones
  assignedTo     User?            @relation(fields: [assignedToId], references: [id])
  activities     ClientActivity[]

  @@map("crm_leads")
}

model ClientActivity {
  id             String           @id @default(uuid())
  type           String           // CALL, EMAIL, MEETING, NOTE, NOC_SYSTEM
  title          String
  description    String
  createdAt      DateTime         @default(now())
  createdById    String
  accountId      String?
  leadId         String?

  // Relaciones
  createdBy      User             @relation(fields: [createdById], references: [id])
  account        CustomerAccount? @relation(fields: [accountId], references: [id])
  lead           Lead?            @relation(fields: [leadId], references: [id])

  @@map("crm_activities")
}

model Invoice {
  id             String           @id @default(uuid())
  invoiceNumber  String           @unique
  amount         Float
  currency       String           @default("ARS")
  dueDate        DateTime
  status         String           @default("UNPAID") // PAID, UNPAID, OVERDUE, VOID
  paymentMethod  String?
  paidAt         DateTime?
  pdfUrl         String?
  accountId      String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  // Relaciones
  account        CustomerAccount  @relation(fields: [accountId], references: [id])

  @@map("crm_invoices")
}
